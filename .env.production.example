# ============================================================
# .env para PRODUÇÃO (VPS Contabo)
# Renomeia para .env e preenche os valores reais
# NUNCA commitas este ficheiro com valores reais
# ============================================================

# PostgreSQL — usa uma senha forte, não "postgres"
POSTGRES_PASSWORD=GERA_SENHA_FORTE_AQUI
DATABASE_URL=postgresql+asyncpg://postgres:GERA_SENHA_FORTE_AQUI@postgres:5432/leads

# n8n — gera com: python3 -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=GERA_AQUI_COM_COMANDO_ACIMA

# URLs internas (Docker Compose — não alterar)
N8N_BASE_URL=http://n8n:5678
FASTAPI_INTERNAL_URL=http://fastapi:8000
N8N_WEBHOOK_PATH=lead-qualification

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-XXXX

# Apollo.io API (enriquecimento de leads)
APOLLO_API_KEY=XXXX

# Slack (webhook para routing de leads)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
